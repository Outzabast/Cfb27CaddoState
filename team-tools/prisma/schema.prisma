// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// A player's academic class. Includes redshirt variants for each year, plus two
/// lifecycle states: GRADUATED (aged out) and TRANSFERRED (left for another team).
enum PlayerClass {
  FRESHMAN
  REDSHIRT_FRESHMAN
  SOPHOMORE
  REDSHIRT_SOPHOMORE
  JUNIOR
  REDSHIRT_JUNIOR
  SENIOR
  REDSHIRT_SENIOR
  GRADUATED
  TRANSFERRED

  @@map("player_class")
}

/// Where a game was played, from Caddo State's perspective.
enum GameLocation {
  HOME
  AWAY
  NEUTRAL

  @@map("game_location")
}

/// A player's standing with the program. POSTACTIVE means graduated or
/// transferred (off the active roster) — a player whose latest class is
/// GRADUATED/TRANSFERRED must be POSTACTIVE. INJURED = rostered but on IR
/// (see Player.injuryDetails). ACTIVE/INJURED are both "on the roster" for
/// notoriety purposes; POSTACTIVE drops the season baseline to 0.
enum PlayerStatus {
  ACTIVE
  INJURED
  POSTACTIVE

  @@map("player_status")
}

/// A player's stable identity ONLY (name). The `id` lets rosters and game stats
/// refer to the same person across seasons. Anything that changes year to year
/// (class, position, number) lives on SeasonPlayer, not here, so a past season's
/// record is never rewritten when the player advances.
model Player {
  id        Int      @id @default(autoincrement())
  name      String
  // Profile info (not used by the roster). All optional.
  bio           String?
  awards        String?
  notableEvents String? @map("notable_events")
  photo         Bytes?
  // Structured bio for the ESPN-style profile header. A current snapshot on the
  // player (height/weight can drift year to year; kept simple as one value).
  heightInches  Int?         @map("height_inches")
  weightLbs     Int?         @map("weight_lbs")
  hometown      String?
  // Standing with the program (ACTIVE / INJURED / POSTACTIVE). Kept in sync with
  // class: a GRADUATED/TRANSFERRED player is POSTACTIVE. injuryDetails is the
  // optional free-text note shown when INJURED.
  status        PlayerStatus @default(ACTIVE)
  injuryDetails String?      @map("injury_details")
  // Program-wide notoriety: how noteworthy this player is across all seasons.
  // Unsigned (guarded >= 0 in code); ratchets up fast, decays slowly. Says
  // "worth writing about", not good/bad. See also SeasonPlayer.seasonNotoriety
  // and GamePlayerStat.gameNotoriety for the narrower scopes.
  overallNotoriety Int       @default(0) @map("overall_notoriety")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  seasonPlayers   SeasonPlayer[]
  gameStats       GamePlayerStat[]
  media           Media[]
  mediaTags       MediaTag[]
  mediaEvents     MediaEvent[]
  notorietyEvents NotorietyEvent[]
  rosterEvents    PlayerRosterEvent[]
  pressConferences PressConference[]
  /// The recruit record this player came from, if they were signed out of a
  /// recruiting class (null for players added directly to a roster).
  recruit         Recruit?

  @@map("players")
}

/// The kind of roster transaction a PlayerRosterEvent records.
enum RosterEventType {
  JOINED_RECRUIT
  JOINED_TRANSFER
  NAMED_STARTER
  LOST_STARTER
  GRADUATED
  TRANSFERRED_OUT
  OTHER

  @@map("roster_event_type")
}

/// A dated entry in a player's roster history: how/when they joined (signed out of
/// high school, transferred in from another program), left (graduated, transferred
/// out), or changed standing (named starter, lost the job). Some are written
/// automatically at the moment they happen (signing, the offseason, a starter
/// toggle); all can also be added by hand on the player profile.
model PlayerRosterEvent {
  id       Int             @id @default(autoincrement())
  playerId Int             @map("player_id")
  /// The season the event belongs to (drives chronological ordering + labels).
  seasonId Int?            @map("season_id")
  type     RosterEventType
  /// Other program involved — the school a transfer came from / left for.
  counterparty String?
  note      String?
  createdAt DateTime        @default(now()) @map("created_at")

  player Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  season Season? @relation(fields: [seasonId], references: [id], onDelete: SetNull)

  @@index([playerId])
  @@map("player_roster_events")
}

/// Why a press conference is being held. Pre/post GAME is derived from the game's
/// result; SEASON pressers are explicitly pre or post.
enum PressConferenceType {
  PRE_GAME
  POST_GAME
  PRE_SEASON
  POST_SEASON

  @@map("press_conference_type")
}

enum PressConferenceStatus {
  ACTIVE
  DONE

  @@map("press_conference_status")
}

/// An interactive press conference: reporters (author personas) question a player
/// or coach who answers. Built live — each answer prompts the next question (a
/// follow-up or a new reporter) up to the caps. Finalized into a Q&A transcript.
model PressConference {
  id     Int                   @id @default(autoincrement())
  type   PressConferenceType
  status PressConferenceStatus @default(ACTIVE)

  // At the podium (exactly one).
  playerId Int? @map("player_id")
  staffId  Int? @map("staff_id")
  // Context anchor: a game (pre/post) or a season (pre/post).
  gameId   Int? @map("game_id")
  seasonId Int? @map("season_id")

  // Which author personas ask, and the caps.
  personaIds    Int[] @default([]) @map("persona_ids")
  maxPerPersona Int   @default(2)  @map("max_per_persona")
  maxTotal      Int   @default(10) @map("max_total")
  /// When true, each question is voiced with the asking persona's TTS voice.
  speakQuestions Boolean @default(false) @map("speak_questions")

  /// The transcript Media produced when finished (null while active).
  mediaId Int? @unique @map("media_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  player    Player?                   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  staff     Staff?                    @relation(fields: [staffId], references: [id], onDelete: Cascade)
  game      Game?                     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season    Season?                   @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  media     Media?                    @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  questions PressConferenceQuestion[]

  @@map("press_conferences")
}

/// One exchange: a reporter's question and the subject's answer (answer null until
/// responded). `order` is the transcript sequence.
model PressConferenceQuestion {
  id           Int      @id @default(autoincrement())
  conferenceId Int      @map("conference_id")
  order        Int
  /// Asking persona (denormalized name survives persona deletion); null = moderator.
  personaId   Int?    @map("persona_id")
  personaName String  @map("persona_name")
  question    String
  answer      String?
  isFollowUp  Boolean @default(false) @map("is_follow_up")
  /// Spoken question audio (WAV) when the conference voices questions.
  audio       Bytes?
  audioMime   String? @map("audio_mime")
  createdAt   DateTime @default(now()) @map("created_at")

  conference PressConference @relation(fields: [conferenceId], references: [id], onDelete: Cascade)

  @@index([conferenceId])
  @@map("press_conference_questions")
}

/// A manually-attributed notoriety bump: "this happened, and it's worth N to the
/// player's fame." Added on top of the COMPUTED program (overall) notoriety, so it
/// survives recompute; delete it and overall eases back down (ratcheted). Distinct
/// from the free-text `notableEvents` string — this one carries a points value.
model NotorietyEvent {
  id          Int      @id @default(autoincrement())
  playerId    Int      @map("player_id")
  description String
  points      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([playerId])
  @@map("notoriety_events")
}

/// A single season, e.g. "2026-2027" spanning startYear -> endYear. Each season
/// has exactly one roster.
model Season {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  startYear Int      @map("start_year")
  endYear   Int      @map("end_year")
  /// The conference the team played in this season (free text, e.g. "Sun Belt").
  conference String?
  /// Fan sentiment, 0–100 (0 furious, 50 neutral, 100 elated). Starts from a
  /// baseline (derived from prior seasons, or `sentimentBaselineOverride` when
  /// set) and moves with performance vs. expectation. Carries over: a season's
  /// final sentiment feeds the next season's derived baseline. Drives media tone.
  fanSentiment              Int  @default(50) @map("fan_sentiment")
  /// Optional manual override of the derived preseason baseline (0–100). Null =
  /// use the value derived from recent past performance.
  sentimentBaselineOverride Int? @map("sentiment_baseline_override")
  createdAt DateTime @default(now()) @map("created_at")

  roster SeasonRoster?
  games  Game[]
  staff       SeasonStaff[]
  media       Media[]
  mediaTags   MediaTag[]
  mediaEvents MediaEvent[]
  facts       Fact[]
  recruits    Recruit[]
  rosterEvents PlayerRosterEvent[]
  pressConferences PressConference[]

  @@map("seasons")
}

/// The topical layer a standing fact belongs to. TEAM facts are global (seasonId
/// null) program canon that supplements TEAM_FACTS; SEASON facts are that season's
/// storylines; ROSTER facts are that season's roster context. Both season-scoped
/// layers require a seasonId.
enum FactScope {
  TEAM
  SEASON
  ROSTER

  @@map("fact_scope")
}

/// A piece of standing editorial context injected into media generation across
/// many articles — the "stuff the stats don't show" you'd otherwise retype into
/// every prompt (rebuilding year, poached coordinator, thin at DB…). One fact per
/// row. Assembled per-article by scope; see lib/media/facts.ts.
model Fact {
  id        Int       @id @default(autoincrement())
  scope     FactScope
  /// Null for TEAM (global). Required for SEASON/ROSTER — the season it describes.
  seasonId  Int?      @map("season_id")
  body      String
  /// How important this fact is, 0–100. Facts at/above FACT_AUTOINJECT_THRESHOLD
  /// are force-injected into every relevant piece; the rest stay out of context
  /// but are researchable on demand via the list_facts tool (keeps context lean
  /// as the archive grows). See lib/media/facts.ts + constants.ts.
  importance Int      @default(50)
  /// Inactive facts stay authored but aren't injected — a toggle, not a delete.
  active    Boolean   @default(true)
  /// Ascending display + injection order within a (scope, season) group.
  sortOrder Int       @default(0) @map("sort_order")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  season Season? @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([scope, seasonId])
  @@map("facts")
}

/// Where a recruit stands in the recruiting funnel, relative to our program.
/// TARGET (on the board) → OFFERED → COMMITTED (verbal) → SIGNED (LOI) →
/// ENROLLED (on campus). DECOMMITTED / LOST are the ways it falls through.
enum RecruitStatus {
  TARGET
  OFFERED
  COMMITTED
  SIGNED
  ENROLLED
  DECOMMITTED
  LOST

  @@map("recruit_status")
}

/// Where a recruit is coming FROM. HIGH_SCHOOL is a traditional prospect; TRANSFER
/// is a portal add who has already played college ball elsewhere (they arrive with
/// a previous school + remaining eligibility rather than a class rank).
enum RecruitKind {
  HIGH_SCHOOL
  TRANSFER

  @@map("recruit_kind")
}

/// A recruiting prospect the program is tracking. Deliberately NOT a Player: a
/// recruit who never signs never played for us, and a recruit belongs to a
/// recruiting CLASS (its season) so 2026-2027 targets don't blur into 2027-2028.
/// Carries its own identity + 247-style scouting data. When a recruit signs they
/// BECOME a player who played here: `playerId` is filled (and a SeasonPlayer is
/// created) at that point — the Recruit row stays as the prospect history.
model Recruit {
  id       Int    @id @default(autoincrement())
  /// The recruiting class this prospect belongs to (a season).
  seasonId Int    @map("season_id")
  name     String
  position String @db.VarChar(8)

  /// High-school prospect vs. transfer-portal add.
  kind RecruitKind @default(HIGH_SCHOOL)
  /// TRANSFER only: the program they're coming from, and eligibility remaining.
  previousSchool   String? @map("previous_school")
  eligibilityYears Int?    @map("eligibility_years")

  // Physicals + origin (a recruit's own — not a Player's, since they may never sign).
  heightInches  Int?    @map("height_inches")
  weightLbs     Int?    @map("weight_lbs")
  hometownCity  String? @map("hometown_city")
  hometownState String? @map("hometown_state")
  highSchool    String? @map("high_school")

  // 247-style scouting. stars 0–5; rating is the composite (0–1, e.g. 0.9421);
  // ranks are national / positional / state (nullable — not every prospect is ranked).
  stars        Int    @default(0)
  rating       Float?
  nationalRank Int?   @map("national_rank")
  positionRank Int?   @map("position_rank")
  stateRank    Int?   @map("state_rank")

  // Funnel + color.
  status      RecruitStatus @default(TARGET)
  committedAt DateTime?     @map("committed_at")
  /// Other programs competing for / that landed the prospect (free text).
  otherOffers String?       @map("other_offers")
  bio         String?
  notes       String?
  photo       Bytes?

  /// Set when the recruit signs and becomes one of our players. Unique: a recruit
  /// maps to at most one player, and vice versa. SetNull so deleting the player
  /// doesn't erase the prospect history.
  playerId Int? @unique @map("player_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  season      Season       @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  player      Player?      @relation(fields: [playerId], references: [id], onDelete: SetNull)
  media       Media[]
  mediaEvents MediaEvent[]

  @@index([seasonId])
  @@index([status])
  @@map("recruits")
}

/// A coaching role held for a season. Fixed set for now; extensible later.
enum StaffRole {
  HEAD_COACH
  OFFENSIVE_COORDINATOR
  DEFENSIVE_COORDINATOR

  @@map("staff_role")
}

/// A staff member's stable identity (name) + profile. Season-to-season role and
/// notoriety live on SeasonStaff, mirroring Player/SeasonPlayer. Notoriety applies
/// to staff too (role baseline + team performance + longevity).
model Staff {
  id               Int      @id @default(autoincrement())
  name             String
  bio              String?
  photo            Bytes?
  /// Program-wide notoriety (unsigned, ratcheted) — see SeasonStaff.seasonNotoriety.
  overallNotoriety Int      @default(0) @map("overall_notoriety")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  seasonStaff      SeasonStaff[]
  media            Media[]
  mediaEvents      MediaEvent[]
  pressConferences PressConference[]

  @@map("staff")
}

/// One staff member in one season: their role and that season's notoriety. At most
/// one person per role per season.
model SeasonStaff {
  id              Int       @id @default(autoincrement())
  seasonId        Int       @map("season_id")
  staffId         Int       @map("staff_id")
  /// Denormalized Staff.name for display without a join.
  staffName       String    @map("staff_name")
  role            StaffRole
  seasonNotoriety Int       @default(0) @map("season_notoriety")

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([seasonId, role])
  @@index([staffId])
  @@map("season_staff")
}

/// The team's roster for one season: the collection of players on the team and
/// the state they were in that year (via its SeasonPlayer rows). One per season.
model SeasonRoster {
  id       Int @id @default(autoincrement())
  seasonId Int @unique @map("season_id")

  season  Season         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  players SeasonPlayer[]

  @@map("season_rosters")
}

/// One player as they existed in a specific season: their class, position, and
/// jersey number FOR THAT SEASON. Advancing to the next season creates new
/// SeasonPlayer rows (with stepped-up classes) and leaves prior ones untouched,
/// so history is preserved.
model SeasonPlayer {
  id             Int         @id @default(autoincrement())
  seasonRosterId Int         @map("season_roster_id")
  playerId       Int         @map("player_id")
  /// Denormalized copy of Player.name, kept in sync at creation (names are never
  /// edited after that). Exists so a roster can enforce unique player names.
  playerName     String      @map("player_name")
  position       String      @db.VarChar(8)
  class          PlayerClass
  number         Int?
  /// Whether this player starts for the team this season. Sets the notoriety
  /// baseline (starters begin higher) and feeds the significance calc.
  isStarter      Boolean     @default(false) @map("is_starter")
  /// Notoriety within THIS season only (unsigned, guarded >= 0 in code).
  /// Ratchets up fast, decays slowly. See Player.overallNotoriety for program-wide.
  seasonNotoriety Int        @default(0) @map("season_notoriety")

  seasonRoster SeasonRoster @relation(fields: [seasonRosterId], references: [id], onDelete: Cascade)
  player       Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([seasonRosterId, playerId])
  @@unique([seasonRosterId, playerName])
  @@map("season_players")
}

/// One game in a season, with the final scoreboard. Player and team stat lines
/// hang off this. Season/career totals are SQL views that aggregate these games
/// (see the stat_views migration), so they never drift from the box scores.
model Game {
  id         Int          @id @default(autoincrement())
  seasonId   Int          @map("season_id")
  week       Int?
  date       DateTime?    @db.Date
  opponent   String
  location   GameLocation @default(HOME)
  /// Whether this is a conference game (feeds the conference W-L record).
  isConference Boolean    @default(false) @map("is_conference")
  /// Optional short billing for the game — "CUSA title game", "bowl: Frisco Bowl",
  /// "rivalry week". Shown on the schedule and fed to media for richer coverage.
  note       String?
  /// A one-paragraph game summary, generated from the play-by-play in a chosen
  /// persona's voice (editable). Shown on the box score under the score.
  summary    String?
  // Final score (kept as the source of truth for W/L + season aggregation). When
  // quarter scores are entered, these are set to the sum of the quarters + OT.
  teamPoints Int          @default(0) @map("team_points")
  oppPoints  Int          @default(0) @map("opp_points")
  // Per-quarter scoring. OT is a single bucket (0 when the game didn't go to OT).
  teamQ1     Int          @default(0) @map("team_q1")
  teamQ2     Int          @default(0) @map("team_q2")
  teamQ3     Int          @default(0) @map("team_q3")
  teamQ4     Int          @default(0) @map("team_q4")
  teamOt     Int          @default(0) @map("team_ot")
  oppQ1      Int          @default(0) @map("opp_q1")
  oppQ2      Int          @default(0) @map("opp_q2")
  oppQ3      Int          @default(0) @map("opp_q3")
  oppQ4      Int          @default(0) @map("opp_q4")
  oppOt      Int          @default(0) @map("opp_ot")
  createdAt  DateTime     @default(now()) @map("created_at")

  season       Season           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  playerStats    GamePlayerStat[]
  oppPlayerStats GameOppPlayerStat[]
  teamStats      GameTeamStat?
  oppStats       GameOppStat?
  scoringPlays   ScoringPlay[]
  plays        GamePlay[]
  media        Media[]
  mediaTags    MediaTag[]
  mediaEvents  MediaEvent[]
  pressConferences PressConference[]

  @@unique([seasonId, week])
  @@map("games")
}

/// One play from a game's in-game play-by-play (drive/flow log), imported by OCR.
/// Drives are derived on read by grouping consecutive plays with the same
/// possessing `team`. Gives media rich, sequential recall of how a game unfolded.
model GamePlay {
  id      Int         @id @default(autoincrement())
  gameId  Int         @map("game_id")
  quarter Int
  /// Game clock the play started at, "mm:ss" as shown.
  clock   String?
  /// Which side had the ball (TEAM = Caddo State).
  team    ScoringTeam
  /// The down-and-distance / field-position line, e.g. "1st & 10 on NIU 25".
  situation String?
  /// The play description, e.g. "Ryan Browne pass to Joe Stein for 6 yards."
  description String
  /// Chronological order across the whole game.
  sortOrder Int @default(0) @map("sort_order")
  /// Manual drive-boundary override for the derived play-by-play grouping.
  /// null = automatic (new drive when possession changes); true = force a split
  /// (start a new drive here even on unchanged possession); false = force a merge
  /// (keep this play on the previous drive even though possession changed).
  newDrive Boolean? @map("new_drive")
  /// Typed outcome of the play — drives the derived score and drive result without
  /// parsing the description text. Legacy rows default to SCRIMMAGE.
  playType PlayType @default(SCRIMMAGE) @map("play_type")
  /// Points this play put on the board (0 for non-scoring plays).
  points Int @default(0)
  /// Which team the points went to. Usually the possessing team, but the OTHER
  /// team on a pick-six / return TD / safety. null when no points were scored.
  scoringTeam ScoringTeam? @map("scoring_team")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("game_plays")
}

/// The typed result of a play-by-play play. Distinguishes scoring plays and
/// drive-concluders so the score and drive outcome are computed from data, not
/// guessed from the description text. Points/scoringTeam carry the actual score
/// (so a pick-six is INTERCEPTION with points on the defense).
enum PlayType {
  /// Ordinary rush/pass that continues the drive (the default).
  SCRIMMAGE
  TOUCHDOWN
  EXTRA_POINT
  EXTRA_POINT_MISSED
  TWO_POINT
  TWO_POINT_FAILED
  FIELD_GOAL
  FIELD_GOAL_MISSED
  SAFETY
  PUNT
  INTERCEPTION
  FUMBLE
  TURNOVER_ON_DOWNS
  KICKOFF
  PENALTY
  KNEEL
  END_PERIOD
  OTHER

  @@map("play_type")
}

/// Which side scored a play. TEAM = Caddo State, OPP = the opponent.
enum ScoringTeam {
  TEAM
  OPP

  @@map("scoring_team")
}

/// One entry in a game's scoring summary (the drive-by-drive "who scored when").
/// Imported from the box score's per-quarter scoring-summary screens; gives media
/// generation the shape of how the game actually unfolded, beyond the final line.
model ScoringPlay {
  id     Int @id @default(autoincrement())
  gameId Int @map("game_id")
  /// 1–4 for regulation; 5+ for overtime periods.
  quarter Int
  team    ScoringTeam
  /// Game clock the play occurred at, "mm:ss" as shown (null if unreadable).
  clock String?
  /// The scoring play as written, minus the team tag —
  /// e.g. "Isaac Boone, 34 Yd run (Danny Paul kick)".
  description String
  /// Points the play was worth (7 TD+kick, 6 TD, 3 FG, 2 safety, 8 TD+2pt…), if inferable.
  points Int?
  /// Chronological order across the whole game (quarter asc, clock descending).
  sortOrder Int @default(0) @map("sort_order")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("scoring_plays")
}

/// One player's box-score line for one game. Every counting stat defaults to 0,
/// so a player who dressed but didn't record anything still gets a row. Columns
/// are grouped Offensive / Defensive / Kicking / Other. "*Long" columns are a
/// single-play best (aggregated with MAX, not SUM, in the season/career views).
model GamePlayerStat {
  id       Int @id @default(autoincrement())
  gameId   Int @map("game_id")
  playerId Int @map("player_id")

  // --- Offensive: passing ---
  passCmp  Int @default(0) @map("pass_cmp")
  passAtt  Int @default(0) @map("pass_att")
  passYds  Int @default(0) @map("pass_yds")
  passTd   Int @default(0) @map("pass_td")
  passInt  Int @default(0) @map("pass_int")
  passLong Int @default(0) @map("pass_long")
  sacked   Int @default(0)
  // --- Offensive: rushing ---
  rushAtt  Int @default(0) @map("rush_att")
  rushYds  Int @default(0) @map("rush_yds")
  rushTd   Int @default(0) @map("rush_td")
  rushLong Int @default(0) @map("rush_long")
  // --- Offensive: receiving ---
  targets Int @default(0)
  rec     Int @default(0)
  recYds  Int @default(0) @map("rec_yds")
  recTd   Int @default(0) @map("rec_td")
  recLong Int @default(0) @map("rec_long")

  // --- Defensive ---
  tacklesSolo    Int   @default(0) @map("tackles_solo")
  tacklesAst     Int   @default(0) @map("tackles_ast")
  tacklesForLoss Float @default(0) @map("tackles_for_loss")
  sacks          Float @default(0)
  qbHurries      Int   @default(0) @map("qb_hurries")
  defInt         Int   @default(0) @map("def_int")
  intYds         Int   @default(0) @map("int_yds")
  passesDefended Int   @default(0) @map("passes_defended")
  forcedFumbles  Int   @default(0) @map("forced_fumbles")
  fumblesRec     Int   @default(0) @map("fumbles_recovered")
  defTd          Int   @default(0) @map("def_td")

  // --- Kicking (place-kicking + punting) ---
  fgMade   Int @default(0) @map("fg_made")
  fgAtt    Int @default(0) @map("fg_att")
  fgLong   Int @default(0) @map("fg_long")
  xpMade   Int @default(0) @map("xp_made")
  xpAtt    Int @default(0) @map("xp_att")
  punts    Int @default(0)
  puntYds  Int @default(0) @map("punt_yds")
  puntLong Int @default(0) @map("punt_long")

  // --- Other (returns + fumbles) ---
  krRet       Int @default(0) @map("kr_ret")
  krYds       Int @default(0) @map("kr_yds")
  krTd        Int @default(0) @map("kr_td")
  prRet       Int @default(0) @map("pr_ret")
  prYds       Int @default(0) @map("pr_yds")
  prTd        Int @default(0) @map("pr_td")
  fumbles     Int @default(0)
  fumblesLost Int @default(0) @map("fumbles_lost")

  /// How noteworthy this player's line was IN THIS GAME (unsigned, guarded >= 0).
  /// A per-game snapshot (not ratcheted) — drives who a recap features, so a
  /// second-stringer who explodes for a game surfaces even with low season/overall.
  gameNotoriety Int @default(0) @map("game_notoriety")

  game   Game   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  mediaTags MediaTag[]

  @@unique([gameId, playerId])
  @@map("game_player_stats")
}

/// Caddo State's team totals for one game (one row per game). These are the
/// team-level figures a box score reports that aren't simple sums of player
/// lines (first downs, third-down conversions, penalties, time of possession).
/// Season team totals are a SQL view over these rows.
model GameTeamStat {
  id     Int @id @default(autoincrement())
  gameId Int @unique @map("game_id")

  // --- Offensive ---
  firstDowns       Int @default(0) @map("first_downs")
  totalOffense     Int @default(0) @map("total_offense")
  totalPlays       Int @default(0) @map("total_plays")
  totalYards       Int @default(0) @map("total_yards")
  passCmp          Int @default(0) @map("pass_cmp")
  passAtt          Int @default(0) @map("pass_att")
  passYds          Int @default(0) @map("pass_yds")
  passTd           Int @default(0) @map("pass_td")
  rushAtt          Int @default(0) @map("rush_att")
  rushYds          Int @default(0) @map("rush_yds")
  rushTd           Int @default(0) @map("rush_td")
  thirdDownConv    Int @default(0) @map("third_down_conv")
  thirdDownAtt     Int @default(0) @map("third_down_att")
  fourthDownConv   Int @default(0) @map("fourth_down_conv")
  fourthDownAtt    Int @default(0) @map("fourth_down_att")
  twoPointConv     Int @default(0) @map("two_point_conv")
  twoPointAtt      Int @default(0) @map("two_point_att")
  redZoneTd        Int @default(0) @map("red_zone_td")
  redZoneFg        Int @default(0) @map("red_zone_fg")
  redZoneTrips     Int @default(0) @map("red_zone_trips")
  turnovers        Int @default(0)
  interceptions    Int @default(0)
  fumblesLost      Int @default(0) @map("fumbles_lost")
  penalties        Int @default(0)
  penaltyYds       Int @default(0) @map("penalty_yds")
  timeOfPossession Int @default(0) @map("time_of_possession_sec")

  // --- Defensive ---
  sacks          Float @default(0)
  tacklesForLoss Float @default(0) @map("tackles_for_loss")
  takeaways      Int   @default(0)
  defTd          Int   @default(0) @map("def_td")

  // --- Kicking / punting ---
  fgMade  Int   @default(0) @map("fg_made")
  fgAtt   Int   @default(0) @map("fg_att")
  xpMade  Int   @default(0) @map("xp_made")
  xpAtt   Int   @default(0) @map("xp_att")
  punts   Int   @default(0)
  puntYds Int   @default(0) @map("punt_yds")
  puntAvg Float @default(0) @map("punt_avg")

  // --- Returns ---
  prYds     Int @default(0) @map("pr_yds")
  krYds     Int @default(0) @map("kr_yds")
  returnYds Int @default(0) @map("return_yds")
  returnTd  Int @default(0) @map("return_td")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("game_team_stats")
}

/// The OPPONENT's team totals for one game (one row per game). Same shape as
/// GameTeamStat — we don't track opponent player stats, just these team figures,
/// which let us measure our defense (yards/points given up). Entered/imported
/// alongside our own team stats on the box score.
model GameOppStat {
  id     Int @id @default(autoincrement())
  gameId Int @unique @map("game_id")

  firstDowns       Int @default(0) @map("first_downs")
  totalOffense     Int @default(0) @map("total_offense")
  totalPlays       Int @default(0) @map("total_plays")
  totalYards       Int @default(0) @map("total_yards")
  passCmp          Int @default(0) @map("pass_cmp")
  passAtt          Int @default(0) @map("pass_att")
  passYds          Int @default(0) @map("pass_yds")
  passTd           Int @default(0) @map("pass_td")
  rushAtt          Int @default(0) @map("rush_att")
  rushYds          Int @default(0) @map("rush_yds")
  rushTd           Int @default(0) @map("rush_td")
  thirdDownConv    Int @default(0) @map("third_down_conv")
  thirdDownAtt     Int @default(0) @map("third_down_att")
  fourthDownConv   Int @default(0) @map("fourth_down_conv")
  fourthDownAtt    Int @default(0) @map("fourth_down_att")
  twoPointConv     Int @default(0) @map("two_point_conv")
  twoPointAtt      Int @default(0) @map("two_point_att")
  redZoneTd        Int @default(0) @map("red_zone_td")
  redZoneFg        Int @default(0) @map("red_zone_fg")
  redZoneTrips     Int @default(0) @map("red_zone_trips")
  turnovers        Int @default(0)
  interceptions    Int @default(0)
  fumblesLost      Int @default(0) @map("fumbles_lost")
  penalties        Int @default(0)
  penaltyYds       Int @default(0) @map("penalty_yds")
  timeOfPossession Int @default(0) @map("time_of_possession_sec")

  sacks          Float @default(0)
  tacklesForLoss Float @default(0) @map("tackles_for_loss")
  takeaways      Int   @default(0)
  defTd          Int   @default(0) @map("def_td")

  fgMade  Int   @default(0) @map("fg_made")
  fgAtt   Int   @default(0) @map("fg_att")
  xpMade  Int   @default(0) @map("xp_made")
  xpAtt   Int   @default(0) @map("xp_att")
  punts   Int   @default(0)
  puntYds Int   @default(0) @map("punt_yds")
  puntAvg Float @default(0) @map("punt_avg")

  prYds     Int @default(0) @map("pr_yds")
  krYds     Int @default(0) @map("kr_yds")
  returnYds Int @default(0) @map("return_yds")
  returnTd  Int @default(0) @map("return_td")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@map("game_opp_stats")
}

/// An OPPONENT player's stat line for one game. Opponents aren't Player objects
/// (we don't track them across seasons), so these are just named lines attached to
/// the game — same stat columns as GamePlayerStat, minus notoriety. Feeds richer
/// recaps ("their QB threw for 358") without polluting our player roster.
model GameOppPlayerStat {
  id         Int    @id @default(autoincrement())
  gameId     Int    @map("game_id")
  playerName String @map("player_name")
  position   String? @db.VarChar(8)

  // Passing
  passCmp  Int @default(0) @map("pass_cmp")
  passAtt  Int @default(0) @map("pass_att")
  passYds  Int @default(0) @map("pass_yds")
  passTd   Int @default(0) @map("pass_td")
  passInt  Int @default(0) @map("pass_int")
  passLong Int @default(0) @map("pass_long")
  sacked   Int @default(0)
  // Rushing
  rushAtt  Int @default(0) @map("rush_att")
  rushYds  Int @default(0) @map("rush_yds")
  rushTd   Int @default(0) @map("rush_td")
  rushLong Int @default(0) @map("rush_long")
  // Receiving
  targets Int @default(0)
  rec     Int @default(0)
  recYds  Int @default(0) @map("rec_yds")
  recTd   Int @default(0) @map("rec_td")
  recLong Int @default(0) @map("rec_long")
  // Defensive
  tacklesSolo    Int   @default(0) @map("tackles_solo")
  tacklesAst     Int   @default(0) @map("tackles_ast")
  tacklesForLoss Float @default(0) @map("tackles_for_loss")
  sacks          Float @default(0)
  qbHurries      Int   @default(0) @map("qb_hurries")
  defInt         Int   @default(0) @map("def_int")
  intYds         Int   @default(0) @map("int_yds")
  passesDefended Int   @default(0) @map("passes_defended")
  forcedFumbles  Int   @default(0) @map("forced_fumbles")
  fumblesRec     Int   @default(0) @map("fumbles_recovered")
  defTd          Int   @default(0) @map("def_td")
  // Kicking / punting
  fgMade   Int @default(0) @map("fg_made")
  fgAtt    Int @default(0) @map("fg_att")
  fgLong   Int @default(0) @map("fg_long")
  xpMade   Int @default(0) @map("xp_made")
  xpAtt    Int @default(0) @map("xp_att")
  punts    Int @default(0)
  puntYds  Int @default(0) @map("punt_yds")
  puntLong Int @default(0) @map("punt_long")
  // Returns / fumbles
  krRet       Int @default(0) @map("kr_ret")
  krYds       Int @default(0) @map("kr_yds")
  krTd        Int @default(0) @map("kr_td")
  prRet       Int @default(0) @map("pr_ret")
  prYds       Int @default(0) @map("pr_yds")
  prTd        Int @default(0) @map("pr_td")
  fumbles     Int @default(0)
  fumblesLost Int @default(0) @map("fumbles_lost")

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@map("game_opp_player_stats")
}

/// What kind of media a piece is. Only ARTICLE ships today; the enum is the seam
/// for future clip/highlight types so the Media table doesn't need reshaping.
enum MediaType {
  ARTICLE
  /// A short, X-style social post (with hashtags from its tags + persona/fan replies).
  XPOST
  /// A radio-style spoken monologue: LLM-written script narrated by an audio model.
  AUDIO

  @@map("media_type")
}

/// Which subject a piece of media is anchored to. This is the discriminator that
/// stands in for the "PlayerMedia / GameMedia / TeamMedia" subclasses: Prisma has
/// no table inheritance, so one Media table + this scope + the matching optional
/// FK (playerId / gameId / seasonId) models the same thing in one queryable place.
enum MediaScope {
  PLAYER
  GAME
  TEAM
  RECRUIT
  STAFF

  @@map("media_scope")
}

/// Lifecycle of a generated piece. Media is created PENDING the moment you check
/// "generate media", flips to GENERATING while the LLM writes, then READY (the
/// inbox shows it, unviewed) or FAILED (with genError). Generation is async, so
/// the save that triggers it never blocks on the model.
enum MediaGenStatus {
  PENDING
  GENERATING
  READY
  FAILED

  @@map("media_gen_status")
}

/// One piece of generated media (today: a news article). The single-table stand-in
/// for the Media parent + PlayerMedia/GameMedia/TeamMedia children: `scope` says
/// which it is, and exactly one of playerId/gameId/seasonId is the required anchor.
/// Extra cross-references (tag a player in a game recap, etc.) live in MediaTag.
model Media {
  id        Int            @id @default(autoincrement())
  mediaType MediaType      @default(ARTICLE) @map("media_type")
  scope     MediaScope
  status    MediaGenStatus @default(PENDING)

  // Content. Null until generation completes; photo is a user-added header image
  // (like Player.photo) — the model doesn't produce images yet. photoCaption is
  // the optional subtitle shown under the image and in the Images gallery.
  headline     String?
  body         String?
  photo        Bytes?
  photoCaption String? @map("photo_caption")
  // AUDIO media: the synthesized WAV bytes + mime + length. body holds the spoken
  // transcript/script. Served via /media/[id]/audio.
  audio        Bytes?
  audioMime    String? @map("audio_mime")
  audioSeconds Int?    @map("audio_seconds")

  // Inbox state: false until you open it, drives the "unviewed" badge on /media.
  viewed Boolean @default(false)

  // Generation metadata. promptContext is the "stuff the stats don't show" you
  // type when triggering (NIL deal, walk-off catch, ...). modelId/costUsd record
  // which OpenRouter model wrote it and the billed cost; genError holds the reason
  // when status is FAILED.
  /// The article angle/template (slug: recap, preview, season, feature, injury…).
  /// Drives which subject brief + writing instruction generation uses. Null falls
  /// back to the scope default.
  angle           String? @map("angle")
  promptContext   String? @map("prompt_context")
  modelId         String? @map("model_id")
  costUsd         Float?  @map("cost_usd")
  genError        String? @map("gen_error")
  authorPersonaId Int?    @map("author_persona_id")
  // The event that produced this piece. Deleting the event deletes its media —
  // the escape hatch for an erroneously-posted event.
  mediaEventId    Int?    @map("media_event_id")

  // Subject anchor. Exactly one is set, matching `scope`. Deleting the subject
  // deletes its media.
  playerId  Int? @map("player_id")
  gameId    Int? @map("game_id")
  seasonId  Int? @map("season_id")
  recruitId Int? @map("recruit_id")
  staffId   Int? @map("staff_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorPersona AuthorPersona? @relation(fields: [authorPersonaId], references: [id], onDelete: SetNull)
  player        Player?        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game          Game?          @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season        Season?        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  recruit       Recruit?       @relation(fields: [recruitId], references: [id], onDelete: Cascade)
  staff         Staff?         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  mediaEvent    MediaEvent?    @relation(fields: [mediaEventId], references: [id], onDelete: Cascade)
  tags          MediaTag[]
  socialReplies SocialReply[]
  pressConference PressConference?

  @@index([scope])
  @@index([viewed])
  @@index([playerId])
  @@index([gameId])
  @@index([seasonId])
  @@index([recruitId])
  @@index([staffId])
  @@index([mediaEventId])
  @@map("media")
}

/// A reply under an X-style social post (XPOST media). From a known AuthorPersona
/// (authorPersonaId set) or a randomly-generated fan (authorPersonaId null, with a
/// made-up handle). Deleting the post deletes its replies.
model SocialReply {
  id              Int      @id @default(autoincrement())
  mediaId         Int      @map("media_id")
  authorPersonaId Int?     @map("author_persona_id")
  /// Display handle, e.g. "@GridironGusto" (personas get their name as a handle too).
  handle          String
  displayName     String?  @map("display_name")
  body            String
  likes           Int      @default(0)
  /// Order within the thread (0 = first reply).
  sortOrder       Int      @default(0) @map("sort_order")
  createdAt       DateTime @default(now()) @map("created_at")

  media         Media          @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  authorPersona AuthorPersona? @relation(fields: [authorPersonaId], references: [id], onDelete: SetNull)

  @@index([mediaId])
  @@map("social_replies")
}

/// What happened to trigger media generation. Posting a box score is the main
/// one; player updates and manual posts round it out.
enum MediaEventType {
  BOX_SCORE
  PLAYER_UPDATE
  MANUAL

  @@map("media_event_type")
}

/// Where an event is in the mediaSpace pipeline. Created PENDING, the listener
/// picks it up (PROCESSING), generates its media, then PROCESSED (or FAILED).
enum MediaEventStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED

  @@map("media_event_status")
}

/// A post to the "mediaSpace": the thing that triggers generation. The mediaSpace
/// is just a listener over these — creating one schedules processing, which reads
/// the subject (using player notoriety to decide who to feature) and produces one
/// or more Media rows tied back here. Delete the event and its media cascade away,
/// so an erroneous post is trivially undone.
model MediaEvent {
  id        Int              @id @default(autoincrement())
  type      MediaEventType
  status    MediaEventStatus @default(PENDING)
  scope     MediaScope
  mediaType MediaType        @default(ARTICLE) @map("media_type")
  /// Article angle slug (recap/preview/season/feature/injury…); null = scope default.
  angle     String?

  // Subject anchor, matching `scope` (as on Media).
  playerId  Int? @map("player_id")
  gameId    Int? @map("game_id")
  seasonId  Int? @map("season_id")
  recruitId Int? @map("recruit_id")
  staffId   Int? @map("staff_id")

  // The editor's added context. `personaIds` = which author personas to write as
  // (one piece each; empty = a single piece in the default voice). `playerIds` =
  // extra players to also generate individual features for (a GAME event fans out
  // to a recap + one feature per listed player); for a PLAYER event they are extra
  // subjects of one article. `gameIds` = focus games (e.g. a player feature centered
  // on those games). All the media an event produces point back at it, so deleting
  // the event removes them together.
  context    String?
  personaIds Int[]   @default([]) @map("persona_ids")
  playerIds  Int[]   @default([]) @map("player_ids")
  gameIds    Int[]   @default([]) @map("game_ids")
  error      String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  player  Player?  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game    Game?    @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season  Season?  @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  recruit Recruit? @relation(fields: [recruitId], references: [id], onDelete: Cascade)
  staff   Staff?   @relation(fields: [staffId], references: [id], onDelete: Cascade)
  media   Media[]

  @@index([status])
  @@index([gameId])
  @@map("media_events")
}

/// A cross-reference from a piece of media to some subject beyond its primary
/// anchor: the "tags" a piece can carry (player, game, season, or a specific
/// box-score line). Drives "related articles" and lets a game recap surface on a
/// tagged player's page. Each row sets exactly one of the optional FKs.
model MediaTag {
  id               Int  @id @default(autoincrement())
  mediaId          Int  @map("media_id")
  playerId         Int? @map("player_id")
  gameId           Int? @map("game_id")
  seasonId         Int? @map("season_id")
  gamePlayerStatId Int? @map("game_player_stat_id")

  media          Media           @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  player         Player?         @relation(fields: [playerId], references: [id], onDelete: Cascade)
  game           Game?           @relation(fields: [gameId], references: [id], onDelete: Cascade)
  season         Season?         @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  gamePlayerStat GamePlayerStat? @relation(fields: [gamePlayerStatId], references: [id], onDelete: Cascade)

  @@index([mediaId])
  @@index([playerId])
  @@index([gameId])
  @@map("media_tags")
}

/// A byline personality: the voice the LLM writes in for a piece of media. `voice`
/// is the system-prompt fragment describing tone/style (e.g. "a hard-nosed beat
/// writer who leads with the defense"). Seeded with one default; managed on the
/// settings page.
model AuthorPersona {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  voice     String
  /// Pin the OpenRouter TEXT model this persona writes with (articles, social,
  /// and the audio script). Null falls back to the media type's ModelSetting.
  modelId   String?  @map("model_id")
  /// OpenAI TTS voice this persona narrates AUDIO media with (alloy, ash, …). Null
  /// falls back to the default voice.
  ttsVoice  String?  @map("tts_voice")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  media         Media[]
  socialReplies SocialReply[]

  @@map("author_personas")
}

/// Which OpenRouter model generates each media type. One row per MediaType, set on
/// the settings page. Live per-token pricing is fetched from OpenRouter's /models
/// endpoint at display time, not stored here (it drifts).
model ModelSetting {
  id        Int       @id @default(autoincrement())
  mediaType MediaType @unique @map("media_type")
  modelId   String    @map("model_id")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("model_settings")
}
