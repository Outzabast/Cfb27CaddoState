# Copy this file to `.env` and fill in real values.
# docker-compose reads `.env` automatically for ${VAR} substitution.

# --- Postgres container credentials (used by docker-compose.yml) ---
POSTGRES_USER=caddo
POSTGRES_PASSWORD=change-me
POSTGRES_DB=caddo
POSTGRES_PORT=5432

# --- Connection string for Prisma (team-tools) and the Quarto Python reader ---
# Host is localhost from your machine; use the service name `db` from other containers.
DATABASE_URL=postgresql://caddo:change-me@localhost:5432/caddo

=example_key